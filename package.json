{
  "name": "openscript.ch",
  "private": true,
  "description": "The website of a small software company.",
  "version": "0.1.0",
  "scripts": {
    "start": "gatsby develop",
    "develop": "gatsby develop",
    "build": "gatsby build",
    "build:with-prefix": "gatsby build --prefix-paths",
    "build:types": "graphql-codegen --config codegen.yml",
    "clean": "gatsby clean",
    "check:types": "tsc --noEmit",
    "check:format": "eslint . --max-warnings=0 --ext .ts,.tsx,.js",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@babel/core": "^7.12.3",
    "@emotion/core": "^10.1.1",
    "@emotion/styled": "^10.0.27",
    "@formatjs/intl-pluralrules": "^3.5.6",
    "@formatjs/intl-relativetimeformat": "^7.3.6",
    "@svgr/webpack": "^5.5.0",
    "embla-carousel": "^4.1.0",
    "gatsby": "^2.27.0",
    "gatsby-image": "^2.6.0",
    "gatsby-plugin-emotion": "^4.5.0",
    "gatsby-plugin-manifest": "^2.7.0",
    "gatsby-plugin-react-helmet": "^3.5.0",
    "gatsby-plugin-robots-txt": "^1.5.3",
    "gatsby-plugin-sharp": "^2.9.0",
    "gatsby-plugin-sitemap": "^2.7.0",
    "gatsby-plugin-svgr": "^2.0.2",
    "gatsby-plugin-ts-config": "^1.1.1",
    "gatsby-remark-copy-linked-files": "^2.5.0",
    "gatsby-remark-images": "^3.6.0",
    "gatsby-source-filesystem": "^2.6.0",
    "gatsby-transformer-remark": "^2.11.0",
    "gatsby-transformer-sharp": "^2.7.0",
    "graphql": "14.7.0",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-helmet": "^6.1.0",
    "react-intl": "^5.10.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^1.19.2",
    "@graphql-codegen/typescript": "^1.17.11",
    "@graphql-codegen/typescript-operations": "^1.17.10",
    "@types/node": "^14.14.8",
    "@types/react": "^16.9.56",
    "@types/react-dom": "^16.9.9",
    "@types/react-helmet": "^6.1.0",
    "@typescript-eslint/eslint-plugin": "^4.8.1",
    "@typescript-eslint/parser": "^4.8.1",
    "eslint": "^7.13.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-prettier": "^3.1.4",
    "husky": "^5.0.0-beta.0",
    "prettier": "2.1.2",
    "typescript": "^4.0.5"
