---
import Heading from "./Heading.astro";

/**
 * Accordion Item Component
 *
 * @description An individual accordion item that can be expanded/collapsed with smooth animations
 */

interface Props {
  /**
   * Id of the item
   */
  id: string;

  /**
   * Additional classes to apply to the item
   */
  class?: string;
  /**
   * Title text displayed in the accordion header
   */
  title: string;
  /**
   * Optional name attribute for the details element
   */
  name?: string;
  /**
   * Heading level for the title (h1-h6)
   * @default 'h3'
   */
  headingLevel?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  /**
   * Visual size of the heading (can differ from semantic level)
   * @default 'h6'
   */
  headingSize?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  /**
   * Visual style variant of the accordion
   * @default 'default'
   */
  variant?: "default" | "chevron";
  /**
   * Whether the accordion item is initially open
   * @default false
   */
  open?: boolean;
  /**
   * HTML attributes to spread on the accordion item
   */
  [key: string]: string | number | boolean | undefined;

  /**
   * Allow item to be opened by the id in the url
   */
  openOnUrlReference?: boolean;
}

const {
  id,
  class: className,
  title,
  name,
  headingLevel = "h3",
  headingSize = "h6",
  variant = "default",
  open = false,
  openOnUrlReference = true,
  ...rest
} = Astro.props;
---

<li id={id} class:list={["item", className]} {...rest} data-dynamic={openOnUrlReference}>
  <details class:list={["wrapper", `variant-${variant}`]} name={name} {...open ? { open } : {}}>
    <summary class="title">
      <Heading level={headingLevel} size={headingSize}>
        {
          variant === "chevron" ? (
            <>
              {title}
              <span class="icon-chevron">
                <svg aria-hidden="true" width="12" height="8" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M1.4 1.6L6 6.2l4.6-4.6"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </>
          ) : (
            <>
              <span class="icon-plus">
                <svg aria-hidden="true" width="20" height="2" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill="currentColor" d="M20 .5v1H0v-1z" />
                </svg>
                <svg width="2" height="20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill="currentColor" d="M1.5 20h-1V0h1z" />
                </svg>
              </span>
              {title}
            </>
          )
        }
      </Heading>
    </summary>
    <div class="content">
      <slot />
    </div>
  </details>
</li>

<style>
  :where(.wrapper) {
    --transition-duration: 0.3s;
    --transition-easing: cubic-bezier(0.165, 0.84, 0.44, 1);
    padding-block: 0;
  }

  .title :global(.heading) {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-inline-size: 100%;
  }

  @media (prefers-reduced-motion: no-preference) {
    :where(.wrapper) {
      interpolate-size: allow-keywords;
    }
  }

  details::details-content {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height var(--transition-duration) var(--transition-easing),
      opacity var(--transition-duration) var(--transition-easing);
  }

  details[open]::details-content {
    max-height: 10000px;
    opacity: 1;
  }

  .wrapper.variant-default .content {
    padding: 0 0 1.5rem 2.2rem;
  }

  .wrapper.variant-chevron .title :global(.heading) {
    justify-content: space-between;
  }

  .wrapper.variant-chevron .content {
    padding-block-end: 2.2rem;
  }

  :where(.title) {
    display: flex;
    cursor: pointer;
    padding-block: 0.75rem;
    list-style: none;
  }

  :where(.title)::marker,
  :where(.title)::-webkit-details-marker {
    display: none;
    content: "";
  }

  :where(.title:hover),
  :where(.title:focus-visible) {
    color: var(--color-secondary);
  }

  :where(.icon-plus) {
    display: inline-block;
    position: relative;
    aspect-ratio: 1;
    block-size: 20px;
  }

  :where(.icon-plus svg) {
    position: absolute;
  }

  :where(.icon-plus svg:first-of-type) {
    transform: translateY(-50%);
    inset-block-start: 50%;
    inset-inline-start: 0;
  }

  :where(.icon-plus svg:last-of-type) {
    transform: translateY(-50%);
    inset-block-start: 50%;
    inset-inline-start: 50%;
  }

  @media (prefers-reduced-motion: no-preference) {
    :where(.icon-plus svg:last-of-type) {
      transition: all var(--transition-duration) var(--transition-easing);
    }
  }

  :where(.icon-chevron) {
    flex-shrink: 0;
    display: flex;
    height: 100%;
    align-items: center;
  }

  @media (prefers-reduced-motion: no-preference) {
    :where(.icon-chevron svg) {
      transition: transform var(--transition-duration) var(--transition-easing);
    }
  }

  :where(.content a) {
    display: inline-block;
  }

  :where(.content > *:not(:first-child)) {
    margin-block-start: 0.75rem;
  }

  :where(.wrapper[open] .icon-plus svg:last-of-type) {
    transform: rotate(90deg);
    inset-block-start: 0;
  }

  :where(.wrapper[open] .icon-chevron svg) {
    transform: scaleY(-1);
  }
</style>

<script>
  const setInitialOpenAccordion = () => {
    const hash = window.location.hash;

    if (!hash) return;

    const id = hash.split("#")[1];

    if (!id) return;
    const element = document.getElementById(id);

    if (!element) return;

    const dynamicOpening = element.dataset.dynamic;

    if (!dynamicOpening) return;

    const details = element.getElementsByTagName("details");

    if (details.length === 1) {
      details[0]?.setAttribute("open", "");
    }
  };

  setInitialOpenAccordion();
</script>
