{
  "include": ["./src/**/*", "./.gatsby/*"],
  "compilerOptions": {
    "module": "esnext",
    "target": "es2018",
    "jsx": "preserve",
    "lib": ["dom"],
    // "allowJs": true,
    // "checkJs": true,
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  }
}
